# ElevenLabs - dublaj + coklu konusmaci diarization (Scribe)
# Alinacak yer: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# Groq Whisper API - hizli transkripsiyon
# Alinacak yer: https://console.groq.com (ucretsiz)
GROQ_API_KEY=gsk_...

# OpenRouter - LLM ceviri
# Alinacak yer: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Opsiyonel: farkli model secmek icin (default: deepseek/deepseek-chat-v3-0324)
# OPENROUTER_MODEL=google/gemini-flash-1.5

# Opsiyonel: STT fallback modeli (Groq limitine takilinca kullanilir)
# Varsayilan: openai/whisper-large-v3-turbo
# OPENROUTER_STT_MODEL=openai/whisper-large-v3-turbo
# OPENROUTER_STT_CHUNK_SEC=30

# Opsiyonel: Sync.so AI lipsync (ucretli)
# Alinacak yer: https://sync.so
# SYNC_API_KEY=sk-...

# Flask ayarlari
PORT=8899
HOST=127.0.0.1
