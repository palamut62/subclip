# Groq Whisper API - ucretsiz, cok hizli transkripsiyon
# Alinacak yer: https://console.groq.com (ucretsiz hesap)
GROQ_API_KEY=gsk_...

# Opsiyonel: Google Colab Whisper endpoint (en hizli secenek)
# colab_whisper.ipynb notebook'unu calistirip URL'yi buraya koy
COLAB_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app

# OpenRouter - LLM ile ceviri (cok ucuz, ~$0.006 / 250 dk video)
# Alinacak yer: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Opsiyonel: farkli model secmek icin (default: deepseek/deepseek-chat-v3-0324)
# OPENROUTER_MODEL=google/gemini-flash-1.5

# Flask ayarlari
PORT=8899
HOST=127.0.0.1
